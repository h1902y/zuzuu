# macOS
.DS_Store

# Node
node_modules/

# Generated traces from experiments (regenerable from host logs; never committed)
experiments/**/out/

# Git-native session store: the index is tracked (small, links to commits);
# the bulky OTLP trace blobs stay local until Phase 2's orphan branch.
# Transient liveness state for in-flight sessions (like .git/ session state).

# Local host-enablement config written by `mns enable` (regenerable; not ours to track)
.opencode/
.claude/settings.json
.claude/settings.local.json
.claude/worktrees/

# Local agent planning scratch (ce-plan output; not product docs)
docs/plans/

# Ad-hoc design-research screenshots (the written research in docs/design-research/ is tracked)
docs/design-research/shots/

# Personal/marketing federation layer — local-only, read by the personal vault.
# (Older copies exist in git history from before this split.)
.personal/
*.tgz

web-app/

# folded workbench build output (Rung 6 stages it to web-app/)
web/v2/dist/

# zuzuu (ephemeral/derived) — the durable brain (incl. .generations/) travels; these don't
.zuzuu/.live/
.zuzuu/.worktrees/
.zuzuu/.index.db

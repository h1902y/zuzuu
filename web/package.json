{
  "name": "@zuzuucodes/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "zuzuu visual workbench — one folded package: a local daemon (server/) serving a fresh SPA (client/), sharing one wire protocol (shared/).",
  "bin": {
    "zz-web": "./bin/zz-web.js"
  },
  "comment:imports": "#shared resolves to the TS source for typecheck (types) and dev (development condition, set by dev:daemon), and to the built ./dist/shared at runtime (default) so `node dist/server/cli.js` works in a checkout. vitest uses its own alias. The staged web-app/package.json points it straight at ./dist/shared.",
  "imports": {
    "#shared/*": {
      "types": "./src/shared/*",
      "development": "./src/shared/*",
      "default": "./dist/shared/*"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev:client": "vite",
    "dev:daemon": "NODE_OPTIONS=--conditions=development tsx watch src/server/cli.ts -- --no-open --dev --token dev",
    "build:server": "tsc -p tsconfig.build.json",
    "build:client": "vite build",
    "build": "node scripts/build-web.mjs"
  },
  "comment:dependencies": "DAEMON runtime deps only — these become @zuzuucodes/cli optionalDependencies. The client deps are build-time (the SPA ships as pre-built static assets), so they live in devDependencies.",
  "dependencies": {
    "@fontsource/space-mono": "^5.2.9",
    "@hono/node-server": "^2.0.4",
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "archiver": "^8.0.0",
    "chokidar": "^5.0.0",
    "hono": "^4.12.25",
    "lucide-react": "^1.21.0",
    "ws": "^8.21.0"
  },
  "comment:devDependencies": "CLIENT (bundled into dist/web) + build/test tooling. @zuzuu-web/protocol is gone — the protocol is now src/shared, imported via the #shared/* subpath.",
  "devDependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@fontsource-variable/elms-sans": "^5.2.1",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/train-one": "^5.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.101.0",
    "@types/archiver": "^8.0.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "emoji-mart": "^5.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-textarea-autosize": "^8.5.9",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "zustand": "^5.0.14"
  },
  "overrides": {
    "dompurify": "^3.4.11"
  }
}

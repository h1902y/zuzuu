{
  "name": "@zuzuucodes/web",
  "version": "0.1.0",
  "description": "Native-feeling terminal + file explorer for your local machine, in the browser",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/h1902y/zuzuu.git",
    "directory": "web/packages/daemon"
  },
  "homepage": "https://github.com/h1902y/zuzuu/tree/main/web#readme",
  "bin": {
    "zuzuu-web": "bin/zuzuu-web.js"
  },
  "files": [
    "bin",
    "dist",
    "web-dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts --no-open --port 7770",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json && cp -r src/shell-integration/*.zsh src/shell-integration/*.bash src/shell-integration/*.fish dist/shell-integration/ && node scripts/vendor-protocol.mjs && npm run bundle:web",
    "bundle:web": "rm -rf web-dist && cp -R ../web/dist web-dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm test"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "archiver": "^8.0.0",
    "chokidar": "^5.0.0",
    "hono": "^4.12.25",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@zuzuu-web/protocol": "^0.1.0",
    "@types/node": "^25.9.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.4",
    "vitest": "^4.1.8"
  },
  "bugs": {
    "url": "https://github.com/h1902y/zuzuu/issues"
  }
}

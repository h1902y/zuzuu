{
  "name": "@zuzuucodes/cli",
  "version": "1.7.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "description": "Give the coding agent you already run (Claude Code, Codex, Gemini CLI, OpenCode, pi) an evolving body of knowledge, memory, actions, and guardrails \u2014 plain markdown notes it queries, runs, and grows from your real sessions, every change human-gated. Zero dependencies.",
  "keywords": [
    "ai-agents",
    "claude-code",
    "codex",
    "gemini-cli",
    "opencode",
    "agent-memory",
    "knowledge-base",
    "guardrails",
    "human-in-the-loop",
    "cli"
  ],
  "homepage": "https://github.com/h1902y/zuzuu#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/h1902y/zuzuu.git"
  },
  "bugs": {
    "url": "https://github.com/h1902y/zuzuu/issues"
  },
  "license": "MIT",
  "author": "Harshit Krishna Choudhary (https://x.com/h1902y)",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "zz": "bin/zuzuu.mjs",
    "zuzuu": "bin/zuzuu.mjs",
    "zuzuu-web": "bin/zuzuu-web.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "web-app/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "zuzuu": "node bin/zuzuu.mjs",
    "test": "node --test 'tests/**/*.test.mjs'",
    "playground": "node tests/playground/run.mjs",
    "prepublishOnly": "npm test",
    "build:web": "node web/scripts/build-web.mjs"
  },
  "optionalDependencies": {
    "@hono/node-server": "^2.0.4",
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "archiver": "^8.0.0",
    "chokidar": "^5.0.0",
    "hono": "^4.12.25",
    "ws": "^8.21.0"
  }
}

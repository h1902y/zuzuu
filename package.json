{
  "name": "zuzuu-web-workspace",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:daemon dev:web",
    "dev:daemon": "npm run dev -w packages/daemon",
    "dev:web": "npm run dev -w @zuzuu-web/web",
    "build": "npm run build -w @zuzuu-web/protocol && npm run build -w @zuzuu-web/web && npm run build -w packages/daemon",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3"
  }
}

{
  "name": "webcode",
  "version": "0.1.0",
  "description": "Native-feeling terminal + file explorer for your local machine, in the browser",
  "type": "module",
  "bin": {
    "webcode": "./bin/webcode.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts --no-open --port 7770",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json && cp -r src/shell-integration/*.zsh src/shell-integration/*.bash src/shell-integration/*.fish dist/shell-integration/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@webcode/protocol": "^0.1.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "archiver": "^8.0.0",
    "chokidar": "^5.0.0",
    "hono": "^4.12.25",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/node": "^25.9.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.4",
    "vitest": "^4.1.8"
  }
}
